<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Sentinel Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
:root{
  --bg:#0b1020;
  --panel:#121a2b;
  --panel-2:#0f1728;
  --border:#24324d;
  --text:#e5e7eb;
  --muted:#94a3b8;
  --accent:#60a5fa;
  --good:#22c55e;
  --warn:#f59e0b;
  --bad:#ef4444;
}
*{box-sizing:border-box}
body{
  background:linear-gradient(180deg,#08101f 0%,#0b1020 100%);
  color:var(--text);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
  margin:0;
  overflow-x:hidden;
}
.wrap{
  max-width:1180px;
  margin:0 auto;
  padding:24px;
}
.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:16px;
  margin-bottom:18px;
  padding:14px 18px;
  background:rgba(11,18,36,0.72);
  border:1px solid var(--border);
  border-radius:18px;
  backdrop-filter:blur(8px);
}
.brand{
  display:flex;
  align-items:center;
  gap:12px;
  font-weight:800;
  letter-spacing:-0.02em;
}
.brand-mark{
  width:12px;
  height:12px;
  border-radius:999px;
  background:var(--accent);
  box-shadow:0 0 18px rgba(96,165,250,.55);
}
.nav{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}
.nav a{
  color:var(--muted);
  text-decoration:none;
  padding:9px 12px;
  border-radius:10px;
  border:1px solid transparent;
  font-size:14px;
}
.nav a:hover{
  color:var(--text);
  border-color:var(--border);
  background:rgba(255,255,255,0.03);
}
.hero{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:20px;
  margin-bottom:18px;
}
.hero-left h1{
  margin:0;
  font-size:34px;
  line-height:1.1;
}
.hero-left p{
  margin:10px 0 0 0;
  color:var(--muted);
  font-size:15px;
  max-width:760px;
}
.subtle{
  margin-top:8px;
  font-size:14px;
  color:var(--muted);
}
.stats{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:16px;
  margin-bottom:22px;
}
.stat{
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:18px;
  padding:18px;
}
.stat-label{
  color:var(--muted);
  font-size:13px;
  margin-bottom:10px;
  text-transform:uppercase;
  letter-spacing:.04em;
}
.stat-value{
  font-size:28px;
  font-weight:800;
  line-height:1;
}
.section-title{
  font-size:13px;
  text-transform:uppercase;
  letter-spacing:.08em;
  color:var(--muted);
  margin:26px 0 14px 2px;
}
.grid{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:18px;
  width:100%;
  align-items:start;
}
.grid > *{
  min-width:0;
}
.panel{
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:18px;
  padding:20px;
  box-shadow:0 8px 30px rgba(0,0,0,.18);
  width:100%;
  min-width:0;
  overflow:hidden;
}
.panel h3{
  margin:0 0 14px 0;
  font-size:18px;
}
.span-2{
  grid-column:span 2;
  min-width:0;
}
table{
  width:100%;
  border-collapse:collapse;
  table-layout:fixed;
}
th, td{
  text-align:left;
  padding:10px 8px;
  border-bottom:1px solid var(--border);
  vertical-align:top;
  word-break:break-word;
}
pre, code{
  white-space:pre-wrap;
  word-break:break-word;
  overflow-wrap:anywhere;
}
pre{
  background:var(--panel-2);
  border:1px solid var(--border);
  border-radius:12px;
  padding:14px;
  overflow:auto;
}
.btn{
  display:inline-block;
  padding:8px 12px;
  border-radius:10px;
  text-decoration:none;
  font-weight:600;
}
.btn.approve{
  background:#14532d;
  color:#dcfce7;
}
.btn.reject{
  background:#7f1d1d;
  color:#fee2e2;
}
.empty{
  color:var(--muted);
}
.item{
  background:var(--panel-2);
  border:1px solid var(--border);
  border-radius:14px;
  padding:14px;
  margin-bottom:14px;
}
.item:last-child{
  margin-bottom:0;
}
.item-approved{
  border-color:rgba(34,197,94,0.25);
}
.item-rejected{
  border-color:rgba(239,68,68,0.25);
}
.item-executed{
  border-color:rgba(96,165,250,0.25);
}
.item-review{
  border-color:rgba(245,158,11,0.25);
}
.item-title{
  font-size:15px;
  font-weight:700;
  margin-bottom:12px;
  color:#dbeafe;
}
.meta-grid{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:10px 16px;
  margin-bottom:12px;
}
.meta{
  color:var(--text);
  font-size:14px;
  line-height:1.5;
}
.meta span{
  display:block;
  font-size:12px;
  color:var(--muted);
  margin-bottom:2px;
  text-transform:uppercase;
  letter-spacing:.04em;
}
.reason-line{
  margin-bottom:12px;
}
.timeline{
  display:flex;
  flex-direction:column;
  gap:10px;
}
.timeline-row{
  display:grid;
  grid-template-columns:120px 1fr;
  gap:14px;
  padding:12px 14px;
  border:1px solid var(--border);
  border-radius:10px;
  background:rgba(255,255,255,0.02);
  align-items:start;
}
.timeline-ts{
  font-family:monospace;
  font-size:12px;
  color:var(--muted);
  white-space:nowrap;
}
.timeline-text{
  font-size:14px;
  color:var(--text);
  line-height:1.5;
  word-break:break-word;
}
.pill{
  display:inline-block;
  padding:5px 10px;
  border-radius:999px;
  font-size:12px;
  font-weight:700;
  letter-spacing:.02em;
  border:1px solid transparent;
}
.pill.active{
  background:rgba(34,197,94,0.12);
  color:#dcfce7;
  border-color:rgba(34,197,94,0.28);
}
.pill.suspended,
.pill.revoked{
  background:rgba(239,68,68,0.12);
  color:#fee2e2;
  border-color:rgba(239,68,68,0.28);
}
.pill.legacy{
  background:rgba(148,163,184,0.12);
  color:#e2e8f0;
  border-color:rgba(148,163,184,0.28);
}
#activityChart{
  width:100% !important;
  height:280px !important;
}
.freeze-actions{
  margin-top:12px;
  margin-bottom:18px;
}
@media (max-width: 980px){
  .topbar{
    flex-direction:column;
    align-items:flex-start;
  }
  .hero{
    flex-direction:column;
  }
  .stats{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
  .grid{
    grid-template-columns:1fr;
  }
  .span-2{
    grid-column:span 1;
  }
}
@media (max-width: 640px){
  .wrap{
    padding:18px;
  }
  .stats{
    grid-template-columns:1fr;
  }
  .hero-left h1{
    font-size:28px;
  }
  .meta-grid{
    grid-template-columns:1fr;
  }
  .timeline-row{
    grid-template-columns:1fr;
  }
}
</style>
</head>
<body>
<div class="wrap">
  <div class="topbar">
    <div class="brand">
      <span class="brand-mark"></span>
      <span>Sentinel</span>
    </div>
    <div class="nav">
      <a href="/">Home</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/dashboard#priority-queue">Priority Queue</a>
      <a href="/dashboard#recent-activity">Recent Activity</a>
    </div>
  </div>

  <div class="hero">
    <div class="hero-left">
      <h1>Sentinel Dashboard</h1>
      <p>Deterministic execution control for AI agents. Review approvals, inspect system state, and monitor recent activity from a single operator view.</p>
      <p class="subtle">Live operator view for governed AI actions, queue state, and execution outcomes.</p>
    </div>
  </div>

  <div class="freeze-actions">
    <a class="btn approve" href="/dashboard/freeze/off">Freeze Off</a>
    <a class="btn reject" href="/dashboard/freeze/on">Freeze On</a>
  </div>

  <div class="stats">
    <div class="stat">
      <div class="stat-label">API</div>
      <div class="stat-value" style="color:#22c55e;">ONLINE</div>
    </div>

    <div class="stat">
      <div class="stat-label">Redis</div>
      <div class="stat-value" style="color:#22c55e;">CONNECTED</div>
    </div>

    <div class="stat">
      <div class="stat-label">Freeze</div>
      <div class="stat-value" style="color:{{ 'var(--bad)' if freeze_enabled else 'var(--good)' }}">
        {{ 'ON' if freeze_enabled else 'OFF' }}
      </div>
    </div>

    <div class="stat">
      <div class="stat-label">Needs Review</div>
      <div class="stat-value">{{ needs_human_count }}</div>
    </div>

    <div class="stat">
      <div class="stat-label">Approved</div>
      <div class="stat-value">{{ approved_count }}</div>
    </div>

    <div class="stat">
      <div class="stat-label">Rejected</div>
      <div class="stat-value">{{ rejected_count }}</div>
    </div>

    <div class="stat">
      <div class="stat-label">Executed</div>
      <div class="stat-value">{{ executed_count }}</div>
    </div>

    <div class="stat">
      <div class="stat-label">Agents</div>
      <div class="stat-value">{{ agents_count }}</div>
    </div>
  </div>

  <div class="section-title">System Activity</div>
  <div class="grid">
    <section class="panel span-2">
      <h3>System Activity</h3>
      <canvas id="activityChart"></canvas>
    </section>
  </div>

  <div id="priority-queue" class="section-title">Needs Review Queue</div>
  <div class="grid">
    <div class="span-2">{{ needs_human_panel|safe }}</div>
  </div>

  <div class="section-title">Agents</div>
  <div class="grid">
    <div class="span-2">{{ agents_panel|safe }}</div>
  </div>

  <div id="recent-activity" class="section-title">Recent Activity</div>
  <div class="grid">
    <div class="span-2">{{ timeline_panel|safe }}</div>
  </div>

  <div class="section-title">Decision History</div>
  <div class="grid">
    <div>{{ approved_panel|safe }}</div>
    <div>{{ rejected_panel|safe }}</div>
    <div class="span-2">{{ executed_panel|safe }}</div>
  </div>
</div>

<script>
const ctx = document.getElementById('activityChart');
if (ctx) {
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: ['Executed', 'Approved', 'Rejected', 'Needs Human'],
      datasets: [{
        label: 'Actions',
        data: [
          {{ executed_count|default(0) }},
          {{ approved_count|default(0) }},
          {{ rejected_count|default(0) }},
          {{ needs_human_count|default(0) }}
        ]
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false
    }
  });
}

<script>
(function () {
  const REFRESH_MS = 5000;

  function shouldRefresh() {
    if (document.hidden) return false;
    const active = document.activeElement;
    if (active && ["INPUT", "TEXTAREA", "SELECT"].includes(active.tagName)) return false;
    return true;
  }

  setInterval(() => {
    if (!shouldRefresh()) return;
    window.location.reload();
  }, REFRESH_MS);
})();
</script>
</body>
</html>
